#!/usr/bin/env sh
# ref: https://github.com/koekeishiya/dotfiles/blob/master/yabai/yabairc
#
# scripting addition (SA) について:
#   opacity 設定などに SA が必要。yabai サービス起動時に SA はロード済みのはず。
#   Dock がクラッシュ等で再起動した直後は SA が外れることがあるが、
#   sudo がパスワード入力を要求して signal 経由では再ロードできないため、
#   自動化はしていない。必要になったら `sudo yabai --load-sa` を手動実行する。

# global settings
yabai -m config external_bar                 off:45:0
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
yabai -m config window_placement             second_child
yabai -m config window_opacity               on
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        0.85
yabai -m config split_ratio                  0.50
yabai -m config auto_balance                 on
yabai -m config mouse_modifier               fn
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize

# general space settings
yabai -m config layout         float
yabai -m config top_padding    0
yabai -m config bottom_padding 0
yabai -m config left_padding   0
yabai -m config right_padding  0
yabai -m config window_gap     0

# mission-control desktop labels
# 存在するスペースのみラベルを設定（エラーを無視）
yabai -m space 1 --label code 2>/dev/null || true
yabai -m space 2 --label mail 2>/dev/null || true
yabai -m space 3 --label web 2>/dev/null || true
yabai -m space 4 --label productivity 2>/dev/null || true
yabai -m space 5 --label re 2>/dev/null || true
yabai -m space 6 --label media 2>/dev/null || true
yabai -m space 7 --label social 2>/dev/null || true

yabai -m rule --add app="^Dock" manage=off

# Slackスレッドウィンドウを自動配置（660x1130px、マルチ:左下、シングル:右下）
# window_title_changed を使ってタイトル確定後に動く。スクリプトは冪等で、
# 既に規定サイズなら何もしない。メイン判定とスレッド判定はスクリプト側で行う。
yabai -m signal --add event=window_title_changed app="^Slack$" \
  action="/Users/asonas/bin/yabai-slack-thread-place"

# cmux: スリープ復帰時に高さが縮む問題の暫定対応
# 復帰後に cmux の全ウィンドウをディスプレイ縦いっぱいに戻す
yabai -m signal --add event=system_woke action="/Users/asonas/bin/yabai-fix-cmux-height --wait"

echo "yabai configuration loaded.."
