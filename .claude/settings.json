{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "Bash(git:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cd:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(bundle:*)",
      "Bash(bundle exec:*)",
      "Bash(bundle exec rake:*)",
      "Bash(bundle exec rspec:*)",
      "Bash(bundle exec rubocop:*)",
      "Bash(gemini:*)",
      "Bash(mdv:*)"
    ],
    "deny": [
      "Bash(gh pr create*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\033]0;Claude Code: %s\\007' \"$(basename \"$PWD\")\" > /dev/tty"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/context-injector.js"
          },
          {
            "type": "command",
            "command": "~/.claude/scripts/healthcheck-hook.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "PROMPT=$(cat | jq -r '.prompt // empty' | head -c 60 | tr '\\n' ' '); printf '\\033]0;Claude: %s\\007' \"${PROMPT:-$(basename \"$PWD\")}\" > /dev/tty"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\033]0;\\007' > /dev/tty"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/ghostty-attention.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/lint-on-edit.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date)] $USER: $(jq -r '.tool_input.command')\" >> ~/.claude/command_history.log"
          },
          {
            "type": "command",
            "command": "jq -r 'if .tool_input.command | test(\"rm -rf|dd if=|:(){ :|:& };:\") then {\"decision\": \"block\", \"reason\": \"危険なコマンドは実行できません。別の方法を検討してください。\"} else empty end'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/scripts/statusline-usage.py"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "sorah-spec@sorah-marketplace": true,
    "sorah-guides@sorah-marketplace": true,
    "cman@cman": true
  },
  "extraKnownMarketplaces": {
    "cman": {
      "source": {
        "source": "github",
        "repo": "laiso/cman"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "mcpServers": {
    "memory-vector": {
      "command": "envchain",
      "args": [
        "ollama-api",
        "node",
        "~/workspace/memory-vector-server/dist/index.js"
      ]
    },
    "memory-graph": {
      "command": "~/workspace/memory-graph-server/.venv/bin/memory-graph-server"
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754045182761
  }
}
