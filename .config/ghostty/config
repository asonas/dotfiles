# Release cmd+shift+j/k so they pass through to herdr for workspace navigation.
# (default: cmd+shift+j = write_screen_file:paste)
keybind = cmd+shift+j=unbind
keybind = cmd+shift+k=unbind
keybind = cmd+shift+n=unbind

font-family = "SauceCodePro Nerd Font"
font-family = "源ノ角ゴシック Code JP"

font-feature = -calt
font-feature = -dlig

font-thicken = true
font-thicken-strength = 155

window-save-state = always

maximize = true
# window-padding-x = 5
# window-padding-y = 5
# window-padding-balance = true
# window-theme = ghostty
# background-opacity = 0.95
# background-blur-radius = 20

##custom-shader = "/Users/asonas/ghq/github.com/hackr-sh/ghostty-shaders/cyber-fuji-2020.glsl"
# custom-shader-animation = always

# ウィンドウの余白設定（お好みで）
window-padding-x = 5
window-padding-y = 5
window-padding-balance = true

scrollback-limit = "500000000"
# Removed: this forced Shift+Enter to emit a bare LF (0x0A), which collides with
# the herdr prefix (ctrl+j == LF) and triggered prefix mode. Ghostty supports
# Shift+Enter for Claude Code natively (kitty keyboard protocol), no LF needed.
# keybind = shift+enter=text:\n

background = 282c34
