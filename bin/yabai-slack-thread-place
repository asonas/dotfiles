#!/usr/bin/env bash
# Slack のスレッド／チャンネルのポップアウトを規定位置に配置する。
# window_title_changed signal から呼ばれる前提（YABAI_WINDOW_ID が渡される）。
# タイトル確定後に動くため、Slack の中間ウィンドウ消失による race を回避する。
#
# 配置ルール:
#   - マルチディスプレイ時: display 2 の左下、660x1130
#   - シングルディスプレイ時: display 1 の右下、660x1130
# 対象外:
#   - メインウィンドウ（タイトルに "[メイン]" を含む）
#   - ポップアウトでないもの（タイトルに "スレッド/Thread/チャンネル/Channel" を含まない）
#   - 既に規定サイズかつ規定位置に居るもの（再配置防止）
#
# 発火頻度について:
#   Slack はバッジ数更新でもタイトルを書き換えるため、本スクリプトは
#   1日数百回呼ばれる想定。冪等性ガード（サイズ＋位置一致）で大部分は
#   yabai -m query 2回 + 文字列比較で早期 exit するため、実害はない。

set -uo pipefail

WINDOW_ID="${YABAI_WINDOW_ID:-${1:-}}"
[[ -z "$WINDOW_ID" ]] && exit 0

WINDOW_W=660
WINDOW_H=1130

info=$(yabai -m query --windows --window "$WINDOW_ID" 2>/dev/null) || exit 0
[[ -z "$info" ]] && exit 0

IFS=$'\t' read -r app title cur_x cur_y cur_w cur_h < <(
  echo "$info" | jq -r '[.app, .title, .frame.x, .frame.y, .frame.w, .frame.h] | @tsv'
)

[[ "$app" != "Slack" ]] && exit 0
[[ "$title" == *"[メイン]"* ]] && exit 0
if [[ "$title" != *"スレッド"* && "$title" != *"Thread"* \
   && "$title" != *"チャンネル"* && "$title" != *"Channel"* ]]; then
  exit 0
fi
# メインウィンドウは「（チャンネル）」（全角括弧）+ [メイン] マーカーで判定済みだが、
# 念のため全角括弧入りのチャンネル名は除外する（[メイン] が一時的に欠ける場合の保険）
[[ "$title" == *"（チャンネル）"* ]] && exit 0

display_count=$(yabai -m query --displays | jq 'length')
if [[ "$display_count" -gt 1 ]]; then
  target_display=2
else
  target_display=1
fi

IFS=$'\t' read -r dx dy dw dh < <(
  yabai -m query --displays --display "$target_display" \
    | jq -r '[.frame.x, .frame.y, .frame.w, .frame.h] | @tsv'
)

# yabai の frame は小数で返るが、ピクセル単位の整数演算で十分なので
# ${var%.*} で小数部を落として bash 算術に渡す
if [[ "$display_count" -gt 1 ]]; then
  new_x="${dx%.*}"
else
  new_x=$(( ${dx%.*} + ${dw%.*} - WINDOW_W ))
fi
new_y=$(( ${dy%.*} + ${dh%.*} - WINDOW_H ))

# 既に規定サイズかつ規定位置なら配置済みとみなしてスキップ
if [[ "${cur_w%.*}" == "$WINDOW_W" && "${cur_h%.*}" == "$WINDOW_H" \
   && "${cur_x%.*}" == "$new_x" && "${cur_y%.*}" == "$new_y" ]]; then
  exit 0
fi

is_floating=$(echo "$info" | jq -r '."is-floating"')
if [[ "$is_floating" != "true" ]]; then
  yabai -m window "$WINDOW_ID" --toggle float 2>/dev/null || exit 0
fi
yabai -m window "$WINDOW_ID" --display "$target_display" 2>/dev/null || true
yabai -m window "$WINDOW_ID" --resize abs:"$WINDOW_W":"$WINDOW_H" 2>/dev/null || true
yabai -m window "$WINDOW_ID" --move abs:"$new_x":"$new_y" 2>/dev/null || true
